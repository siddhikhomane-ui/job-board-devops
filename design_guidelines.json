{
  "theme": "dark",
  "archetype": "5 (Jewel & Luxury) mixed with User Preference",
  "vibe": "Modern, clean, professional, student-friendly, and slightly futuristic.",
  "typography": {
    "headings": {
      "family": "Outfit",
      "weights": ["400", "500", "700"],
      "tracking": "tracking-tight",
      "h1": "text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight",
      "h2": "text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-tight",
      "h3": "text-xl sm:text-2xl font-medium",
      "h4": "text-lg sm:text-xl font-medium"
    },
    "body": {
      "family": "Plus Jakarta Sans",
      "weights": ["400", "500"],
      "default": "text-base leading-relaxed text-slate-300",
      "small": "text-sm text-slate-400",
      "overline": "uppercase text-xs tracking-[0.2em] font-medium text-cyan-400"
    }
  },
  "colors": {
    "background": {
      "base": "#0f172a",
      "tailwind": "bg-slate-900"
    },
    "surface": {
      "primary": "bg-slate-800/40",
      "secondary": "bg-slate-800/80",
      "glass": "bg-white/5 backdrop-blur-xl"
    },
    "brand": {
      "primary": "#7c3aed",
      "secondary": "#06b6d4",
      "gradient": "bg-gradient-to-r from-violet-600 to-cyan-500",
      "text_gradient": "bg-clip-text text-transparent bg-gradient-to-r from-violet-400 to-cyan-400"
    },
    "text": {
      "primary": "text-white",
      "secondary": "text-slate-300",
      "muted": "text-slate-400"
    },
    "border": {
      "default": "border-slate-800",
      "glass": "border-white/10",
      "focus": "ring-2 ring-violet-500 ring-offset-2 ring-offset-slate-900"
    },
    "status": {
      "success": "text-emerald-400 bg-emerald-400/10 border-emerald-400/20",
      "warning": "text-amber-400 bg-amber-400/10 border-amber-400/20",
      "danger": "text-rose-400 bg-rose-400/10 border-rose-400/20",
      "info": "text-cyan-400 bg-cyan-400/10 border-cyan-400/20"
    }
  },
  "layout": {
    "spacing": {
      "section_padding": "py-24 px-6 md:px-12 lg:px-24",
      "dashboard_padding": "p-4 md:p-6 lg:p-8",
      "gap_marketing": "gap-8 md:gap-12",
      "gap_dashboard": "gap-4 md:gap-6"
    },
    "grid": {
      "marketing": "grid grid-cols-1 md:grid-cols-8 lg:grid-cols-12",
      "dashboard": "grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4",
      "bento_hero": "col-span-full md:col-span-8 row-span-2",
      "bento_square": "col-span-4 row-span-1"
    },
    "radius": {
      "card": "rounded-2xl",
      "button": "rounded-full",
      "input": "rounded-xl"
    }
  },
  "surfaces_and_components": {
    "cards": {
      "style": "bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6 md:p-8",
      "hover": "hover:bg-white/10 hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-[0_8px_32px_rgba(124,58,237,0.15)]",
      "dashboard_style": "bg-slate-800/50 border border-slate-700/50 rounded-xl p-5"
    },
    "buttons": {
      "primary": "bg-gradient-to-r from-violet-600 to-cyan-500 text-white rounded-full px-6 py-3 font-medium hover:shadow-[0_0_20px_rgba(124,58,237,0.4)] transition-all duration-300",
      "secondary": "bg-white/10 text-white border border-white/20 rounded-full px-6 py-3 font-medium hover:bg-white/20 transition-all duration-300",
      "ghost": "text-slate-300 hover:text-white hover:bg-white/5 rounded-full px-4 py-2 transition-colors"
    },
    "inputs": {
      "style": "bg-slate-900/50 border border-slate-700 text-white rounded-xl px-4 py-3 focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors placeholder:text-slate-500"
    },
    "navbar": {
      "style": "sticky top-0 z-50 w-full backdrop-blur-xl bg-slate-900/60 border-b border-white/10"
    },
    "badges": {
      "style": "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-500/10 text-violet-300 border border-violet-500/20"
    }
  },
  "motion": {
    "default_transition": "transition-all duration-300 ease-in-out",
    "hover_lift": "hover:-translate-y-1",
    "focus_ring": "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-violet-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900"
  },
