  "icons": {
    "library": "lucide-react",
    "stroke_width": "1.5",
    "size": "w-5 h-5"
  },
  "testing": {
    "attributes": "data-testid",
    "convention": "kebab-case, role-based",
    "examples": ["login-form-submit-button", "job-apply-button", "role-selector-seeker"]
  },
  "instructions_to_main_agent": [
    "Strictly follow the color palette: Deep Slate (#0f172a) for backgrounds, gradient (#7c3aed to #06b6d4) for CTAs and highlighted elements.",
    "Do NOT use pure white backgrounds; this is a fully Dark Mode app with glassmorphic cards.",
    "Install and use 'Outfit' font for headings and 'Plus Jakarta Sans' for body text. Headings MUST have tight tracking.",
    "Use 'lucide-react' for all icons.",
    "For the Landing Page: Implement generous spacing (py-24). Create an overlapping/bento grid feel for the feature highlights.",
    "For Dashboards: Implement a control-room layout with tight gaps (gap-4). Use pure Tailwind + Shadcn logic for the Sidebar and Data Cards.",
    "Do not use generic HTML inputs; use fully styled custom or Shadcn inputs for forms.",
    "For images: Only use the URLs provided in the media object. Use 'object-cover' and rounded corners.",
    "Add 'data-testid' to EVERY interactive element (buttons, links, form inputs) to ensure automated testing succeeds."
  ]
}